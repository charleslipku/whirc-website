---
import { url } from '../utils';
import { site } from '../site';

const nav = [
  {
    label: 'About',
    href: url('/about/'),
    children: [
      { label: 'Who We Are', href: url('/about/who-we-are/') },
      { label: 'What We Do', href: url('/about/what-we-do/') },
    ],
  },
  {
    label: 'People',
    href: url('/people/'),
    children: [
      { label: 'Leadership', href: url('/people/#leadership') },
      { label: 'Affiliated Faculty', href: url('/people/#faculty') },
      { label: 'Students & Trainees', href: url('/people/#students') },
    ],
  },
  {
    label: 'Research',
    href: url('/research/'),
    children: [
      { label: 'Focus Areas', href: url('/research/focus-areas/') },
      { label: 'Publications & Projects', href: url('/research/publications/') },
    ],
  },
  {
    label: 'News',
    href: url('/news/'),
    children: [
      { label: 'WHIRC News', href: url('/news/#whirc-news') },
      { label: 'In The News', href: url('/news/#in-the-news') },
    ],
  },
  {
    label: 'Events',
    href: url('/events/'),
    children: [
      { label: 'Upcoming Events', href: url('/events/#upcoming') },
      { label: 'Past Events', href: url('/events/#past') },
    ],
  },
  {
    label: 'Get Involved',
    href: url('/get-involved/'),
    children: [
      { label: 'Faculty & Researchers', href: url('/get-involved/#for-faculty--researchers') },
      { label: 'Students & Trainees', href: url('/get-involved/#for-students--trainees') },
      { label: 'Community Partners', href: url('/get-involved/#for-community-partners') },
      { label: 'Support WHIRC', href: url('/get-involved/#support-whirc') },
    ],
  },
  { label: 'Contact', href: url('/contact/') },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={url('/')}>
      <img src={url('/images/logo.svg')} alt={`${site.shortName} — ${site.title}`} class="brand-logo" />
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Toggle navigation">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Main navigation">
      <ul>
        {nav.map((item) => (
          <li class:list={['nav-item', { 'has-children': item.children }]}>
            <a href={item.href}>{item.label}</a>
            {item.children && (
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li><a href={child.href}>{child.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    nav?.classList.toggle('is-open', !open);
  });

  // 点击菜单链接后移除焦点，避免 :focus-within 让下拉菜单卡住不收回
  // （同页锚点跳转不刷新页面，焦点会一直停留在链接上）
  nav?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      (document.activeElement as HTMLElement | null)?.blur();
      // 移动端：点击后收起整个菜单
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .site-header {
    background: var(--white);
    border-bottom: 4px solid var(--umd-red);
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 1px 4px rgba(35, 31, 32, 0.08);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 108px;
  }
  .brand-logo {
    height: 88px;
    width: auto;
    display: block;
  }

  /* 注意 “>” 只作用于顶层菜单，避免命中嵌套的 .dropdown ul（会把下拉菜单永久撑开） */
  .site-nav > ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.15rem;
  }
  .dropdown,
  .dropdown li {
    list-style: none;
    margin: 0;
  }
  .nav-item {
    position: relative;
  }
  .nav-item > a {
    display: block;
    padding: 0.85rem 0.85rem;
    color: var(--umd-black);
    font-weight: 600;
    font-size: 1.02rem;
    border-bottom: 3px solid transparent;
  }
  .nav-item > a:hover {
    text-decoration: none;
    border-bottom-color: var(--umd-gold);
    color: var(--umd-red);
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 230px;
    background: var(--white);
    box-shadow: var(--shadow-card-hover);
    border-radius: 0 0 var(--radius) var(--radius);
    border-top: 3px solid var(--umd-gold);
    flex-direction: column;
    padding: 0.35rem 0;
  }
  .has-children:hover .dropdown,
  .has-children:focus-within .dropdown {
    display: flex;
  }
  .dropdown a {
    display: block;
    padding: 0.55rem 1.1rem;
    color: var(--umd-black);
    font-size: 0.96rem;
  }
  .dropdown a:hover {
    background: var(--gray-100);
    color: var(--umd-red);
    text-decoration: none;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-toggle-bar {
    display: block;
    width: 28px;
    height: 3px;
    background: var(--umd-black);
    margin: 6px 0;
    border-radius: 2px;
  }

  @media (max-width: 1080px) {
    .nav-toggle {
      display: block;
    }
    .header-inner {
      min-height: 84px;
    }
    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 3px solid var(--umd-red);
      box-shadow: var(--shadow-card-hover);
      max-height: calc(100vh - 90px);
      overflow-y: auto;
    }
    .site-nav.is-open {
      display: block;
    }
    .site-nav > ul {
      flex-direction: column;
      padding: 0.5rem 0;
    }
    .dropdown {
      display: flex;
      position: static;
      box-shadow: none;
      border-top: none;
      padding-left: 1rem;
    }
    .brand-logo {
      height: 62px;
    }
  }
</style>
